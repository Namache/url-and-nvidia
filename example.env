# ============================================================
#  Claude Desktop on Bazzite — Configuration
# ============================================================
#  Copy this file to .env and edit as needed before running setup.sh.
#  .env is excluded from git — your changes stay local.
# ============================================================

# ------------------------------------
# Container settings
# ------------------------------------

# Name of the Distrobox container to create/use.
CONTAINER_NAME="claude-desktop"

# Base image for the container. Ubuntu 24.04 is tested and recommended.
CONTAINER_IMAGE="ubuntu:24.04"

# ------------------------------------
# Directory access
# ------------------------------------

# Directories to mount in the container and expose to Claude Desktop via MCP.
# Space-separated list of absolute host paths. Paths with spaces are not supported.
# All listed directories will be mounted into the container and made available
# to Claude Desktop's filesystem MCP server.
#
# NOTE: Directories are mounted at container creation time. If you add new
# directories after the container already exists, you must recreate it:
#   distrobox rm claude-desktop && ./setup.sh
#
# Default: a single /mnt/git mount point.
# Example with multiple directories:
#   MOUNT_DIRS="/mnt/git /home/user/projects /mnt/data"
MOUNT_DIRS="/mnt/git"
